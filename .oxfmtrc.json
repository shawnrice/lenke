{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "arrowParens": "always",
  "ignorePatterns": ["node_modules/", "dist/", ".tsc_d/", ".nx/"],
  "insertFinalNewline": true,
  "printWidth": 100,
  "semi": true,
  "singleQuote": true,
  "sortImports": true,
  "sortPackageJson": true,
  "trailingComma": "all"
}
