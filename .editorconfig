# Stop EditorConfig from searching parent directories outside the repo.
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
max_line_length = 100 # Mirrors oxfmt's printWidth so editor rulers match the formatter.
trim_trailing_whitespace = true

# rustfmt.toml keeps rustfmt's 4-space default (tab_spaces); mirror it here.
[*.rs]
indent_size = 4

# Trailing whitespace is a hard line break in Markdown.
[*.md]
trim_trailing_whitespace = false
