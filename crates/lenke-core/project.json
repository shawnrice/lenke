{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "lenke-core",
  "projectType": "library",
  "sourceRoot": "crates/lenke-core/src",
  "tags": ["rust"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": { "command": "cargo build --release", "cwd": "crates/lenke-core" },
      "dependsOn": [],
      "outputs": [],
      "cache": false
    },
    "build-wasm": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo build --release --target wasm32-unknown-unknown --no-default-features --features gql,gremlin,ndjson,codecs,arrow",
        "cwd": "crates/lenke-core"
      },
      "inputs": ["default"],
      "outputs": ["{projectRoot}/target/wasm32-unknown-unknown/release/lenke_core.wasm"],
      "cache": true
    },
    "test": {
      "executor": "nx:run-commands",
      "options": { "command": "cargo test", "cwd": "crates/lenke-core" },
      "inputs": ["default"],
      "cache": true
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo clippy --all-targets -- -D warnings",
        "cwd": "crates/lenke-core"
      },
      "inputs": ["default"],
      "cache": true
    },
    "fmt": {
      "executor": "nx:run-commands",
      "options": { "command": "cargo fmt", "cwd": "crates/lenke-core" },
      "cache": false
    },
    "fmt-check": {
      "executor": "nx:run-commands",
      "options": { "command": "cargo fmt --check", "cwd": "crates/lenke-core" },
      "inputs": ["default"],
      "cache": true
    }
  }
}
