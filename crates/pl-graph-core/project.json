{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "pl-graph-core",
  "projectType": "library",
  "sourceRoot": "crates/pl-graph-core/src",
  "tags": ["rust"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": { "command": "cargo build --release", "cwd": "crates/pl-graph-core" },
      "dependsOn": [],
      "outputs": [],
      "cache": false
    },
    "test": {
      "executor": "nx:run-commands",
      "options": { "command": "cargo test", "cwd": "crates/pl-graph-core" },
      "inputs": ["default"],
      "cache": true
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo clippy --all-targets -- -D warnings",
        "cwd": "crates/pl-graph-core"
      },
      "inputs": ["default"],
      "cache": true
    },
    "fmt": {
      "executor": "nx:run-commands",
      "options": { "command": "cargo fmt", "cwd": "crates/pl-graph-core" },
      "cache": false
    },
    "fmt-check": {
      "executor": "nx:run-commands",
      "options": { "command": "cargo fmt --check", "cwd": "crates/pl-graph-core" },
      "inputs": ["default"],
      "cache": true
    }
  }
}
