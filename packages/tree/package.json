{
  "name": "@pl-graph/tree",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.mjs",
  "types": "./dist/types/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build.ts",
    "build:types": "tsc --project tsconfig.types.json",
    "build:esm": "bun build.ts",
    "build:cjs": "tsc --project tsconfig.cjs.json",
    "build:clean": "bun build.ts --clean"
  },
  "devDependencies": {
    "@pl-graph/dev": "workspace:*",
    "@types/bun": "latest",
    "@types/debug": "^4.1.12",
    "bun-types": "latest",
    "debug": "^4.4.0",
    "prettier": "^3.5.2",
    "terser": "^5.39.0"
  },
  "peerDependencies": {
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@pl-graph/fp": "workspace:*",
    "@pl-graph/utils": "workspace:*"
  }
}
