{
  "name": "@lenke/node",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "napi build --platform --release --esm",
        "cwd": "packages/node"
      },
      "outputs": [
        "{projectRoot}/index.js",
        "{projectRoot}/index.d.ts",
        "{projectRoot}/lenke-node.*.node"
      ],
      "cache": true
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node --test",
        "cwd": "packages/node"
      }
    }
  }
}
