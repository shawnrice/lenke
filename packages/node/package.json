{
  "name": "@lenke/node",
  "version": "0.1.0",
  "description": "Fast native Node.js addon (N-API via napi-rs) for the lenke-core graph engine. The idiomatic Node path — no C-ABI marshalling, no dynamic library to locate.",
  "license": "Apache-2.0",
  "files": [
    "index.js",
    "index.d.ts",
    "backend.js",
    "backend.d.ts",
    "*.node"
  ],
  "type": "module",
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./backend": {
      "types": "./backend.d.ts",
      "default": "./backend.js"
    }
  },
  "scripts": {
    "build": "napi build --platform --release --esm",
    "build:debug": "napi build --platform --esm",
    "test": "node --test"
  },
  "dependencies": {
    "@lenke/native": "workspace:*"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.7.2"
  },
  "napi": {
    "binaryName": "lenke-node",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "aarch64-apple-darwin",
      "x86_64-apple-darwin",
      "x86_64-pc-windows-msvc"
    ]
  }
}
