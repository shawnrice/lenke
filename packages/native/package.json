{
  "name": "@lenke/native",
  "description": "JavaScript/TypeScript bindings to the Rust `lenke-core` columnar graph engine, with a single facade over native (FFI) and WebAssembly backends.",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "default": "./dist/esm/index.mjs"
    },
    "./ffi": {
      "types": "./dist/types/backend-ffi.d.ts",
      "default": "./dist/esm/backend-ffi.mjs"
    },
    "./wasm": {
      "types": "./dist/types/backend-wasm.d.ts",
      "default": "./dist/esm/backend-wasm.mjs"
    },
    "./arrow": {
      "types": "./dist/types/arrow.d.ts",
      "default": "./dist/esm/arrow.mjs"
    }
  },
  "scripts": {
    "build": "bun build.ts",
    "build:rust": "cargo build --release --manifest-path ../../crates/lenke-core/Cargo.toml",
    "build:wasm": "cargo build --release --target wasm32-unknown-unknown --no-default-features --features gql,gremlin,ndjson,codecs,arrow --manifest-path ../../crates/lenke-core/Cargo.toml",
    "build:wasm:min": "cargo build --release --target wasm32-unknown-unknown --no-default-features --features gql --manifest-path ../../crates/lenke-core/Cargo.toml",
    "test": "bun test"
  },
  "dependencies": {
    "@lenke/errors": "workspace:*"
  },
  "devDependencies": {
    "@lenke/dev": "workspace:*",
    "@types/bun": "^1.3.13",
    "apache-arrow": "^21.1.0",
    "bun-types": "latest"
  },
  "peerDependencies": {
    "apache-arrow": ">=17",
    "typescript": "^6.0.0"
  },
  "peerDependenciesMeta": {
    "apache-arrow": {
      "optional": true
    }
  }
}
