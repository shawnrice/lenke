{
  "name": "@pl-graph/list",
  "module": "dist/index.js",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "bun run build:esm && bun run build:types",
    "build:esm": "bun build src/index.ts --minify --splitting --sourcemap --format esm --outdir dist",
    "build:types": "bun run tsc --emitDeclarationOnly --outDir dist"
  },
  "devDependencies": {
    "@types/bun": "^1.1.9",
    "@types/debug": "^4.1.12",
    "bun-types": "latest",
    "prettier": "^3.3.3"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@pl-graph/fp": "workspace:*",
    "debug": "^4.3.7"
  }
}
