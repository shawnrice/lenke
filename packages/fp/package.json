{
  "name": "@lenke/fp",
  "description": "Lazy, curried iterable combinators for composing data transformations over any `Iterable`.",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "default": "./dist/esm/index.mjs"
    },
    "./*": {
      "types": "./dist/types/*.d.ts",
      "default": "./dist/esm/*.mjs"
    }
  },
  "scripts": {
    "build": "bun build.ts",
    "test": "bun test",
    "clean:stray-types": "find src -type f \\( -name '*.d.ts' -o -name '*.d.ts.map' \\) -delete"
  },
  "dependencies": {},
  "devDependencies": {
    "@lenke/dev": "workspace:*",
    "@types/bun": "latest",
    "@types/debug": "^4.1.12",
    "bun-types": "latest",
    "debug": "^4.4.3",
    "prettier": "^3.3.3"
  },
  "peerDependencies": {
    "typescript": "^6.0.0"
  }
}
